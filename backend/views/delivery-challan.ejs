<% var pageTitle = 'Delivery Challan'; %>
<%- include('layout/header') %>

<div class="card">
  <div class="card-header" style="display:flex;align-items:center;justify-content:space-between;">
    <h3>Delivery Challan</h3>
    <button class="btn btn-sm btn-outline-maroon" onclick="window.print()"
      style="display:flex;align-items:center;gap:6px;">
      <i class="lucide-printer"></i> Print
    </button>
  </div>

  <% if (orders.length === 0) { %>
    <p style="padding:24px;color:#6B6B6B;">No pending or confirmed orders.</p>
  <% } %>

  <% orders.forEach(function(order) { %>
  <div class="challan-order" style="border:1px solid #e0d6c8;border-radius:10px;margin:16px;padding:20px;page-break-inside:avoid;">

    <!-- Order Header -->
    <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:16px;flex-wrap:wrap;gap:8px;">
      <div>
        <h4 style="margin:0 0 4px;">Order #<%= order.order_id %></h4>
        <div style="color:#6B6B6B;font-size:13px;">
          <span><strong>Customer:</strong> <%= order.customer_name %></span> &nbsp;|
          <span> <strong>Store:</strong> <%= order.store_name || '-' %></span> &nbsp;|
          <span> <strong>Date:</strong> <%= new Date(order.order_date).toLocaleDateString('en-IN') %></span>
        </div>
        <div style="color:#6B6B6B;font-size:12px;margin-top:2px;">
          <strong>Credit Period:</strong> <%= order.creditPeriodLabel %>
        </div>
        <% if (order.store_address) { %>
        <div style="color:#6B6B6B;font-size:12px;margin-top:2px;">
          <strong>Deliver to:</strong> <%= order.store_address %>
        </div>
        <% } %>
      </div>
      <span class="badge badge-<%= order.status %>" style="font-size:12px;"><%= order.status %></span>
    </div>

    <!-- Items Table -->
    <table class="data-table" style="margin:0;">
      <thead>
        <tr>
          <th style="width:70px;">Image</th>
          <th>Product</th>
          <th>Code</th>
          <th>Bundles</th>
          <th>Sarees</th>
          <th>Rate/Pc</th>
          <th>Rate/Bundle</th>
          <th>Line Total</th>
          <th>Warehouse</th>
          <th>Rack No.</th>
          <th>Shelf No.</th>
          <th style="width:36px;text-align:center;" class="no-print">
            <i class="lucide-check-square" title="Packed"></i>
          </th>
        </tr>
      </thead>
      <tbody>
        <% order.items.forEach(function(item) { %>
        <tr>
          <td>
            <% if (item.image_url) { %>
              <img src="<%= item.image_url %>" alt="<%= item.product_name %>"
                style="width:56px;height:56px;object-fit:cover;border-radius:6px;border:1px solid #e0d6c8;" />
            <% } else { %>
              <div style="width:56px;height:56px;border-radius:6px;background:#f5f0e8;display:flex;align-items:center;justify-content:center;color:#aaa;font-size:11px;">No img</div>
            <% } %>
          </td>
          <td style="font-weight:600;"><%= item.product_name %></td>
          <td style="font-size:13px;color:#6B6B6B;"><%= item.product_code %></td>
          <td style="text-align:center;"><%= item.bundles_ordered %></td>
          <td style="text-align:center;"><%= item.sarees_count %></td>
          <td style="text-align:right;">&#8377;<%= Number(item.price_per_saree_at_order || 0).toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></td>
          <td style="text-align:right;">&#8377;<%= Number(item.pricePerBundle || 0).toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></td>
          <td style="text-align:right;font-weight:600;">&#8377;<%= Number(item.bundle_cost || 0).toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></td>
          <td style="font-weight:500;"><%= item.godown_name || '-' %></td>
          <td style="text-align:center;"><%= item.rack_number || '-' %></td>
          <td style="text-align:center;"><%= item.shelf_number || '-' %></td>
          <td style="text-align:center;" class="no-print">
            <input type="checkbox" style="width:18px;height:18px;cursor:pointer;accent-color:#8B1A1A;" title="Mark as packed" />
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>

    <div style="display:flex;justify-content:flex-end;margin-top:12px;">
      <table style="border-collapse:collapse;min-width:340px;font-size:13px;">
        <tr>
          <td style="padding:6px 10px;color:#6B6B6B;">Total Bundles</td>
          <td style="padding:6px 10px;text-align:right;font-weight:600;"><%= order.totalBundles %></td>
        </tr>
        <tr>
          <td style="padding:6px 10px;color:#6B6B6B;">Total Sarees</td>
          <td style="padding:6px 10px;text-align:right;font-weight:600;"><%= order.totalSarees %></td>
        </tr>
        <tr>
          <td style="padding:6px 10px;color:#6B6B6B;">Total Amount</td>
          <td style="padding:6px 10px;text-align:right;font-weight:700;font-size:15px;">&#8377;<%= Number(order.totalAmount || 0).toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></td>
        </tr>
      </table>
    </div>
  </div>
  <% }) %>
</div>

<style>
  @media print {
    .sidebar, .top-header, .no-print { display: none !important; }
    .main-content { margin-left: 0 !important; }
    .card { box-shadow: none !important; }
    .challan-order { page-break-inside: avoid; }
  }
</style>

<%- include('layout/footer') %>
