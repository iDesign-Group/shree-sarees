<% var pageTitle = 'Users'; %>
<%- include('layout/header') %>

<div class="card">
  <div class="card-header">
    <h3>All Users</h3>
    <button class="btn btn-gold" onclick="openUserDrawer()"><i class="lucide-plus"></i> Add User</button>
  </div>

  <table class="data-table">
    <thead>
      <tr>
        <th></th>
        <th>Name</th>
        <th>Email</th>
        <th>Role</th>
        <th>Login Expiry</th>
        <th>Active</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% users.forEach(function(u) { %>
        <tr>
          <td><div class="avatar-circle avatar-sm"><%= u.name.charAt(0).toUpperCase() %></div></td>
          <td><strong><%= u.name %></strong></td>
          <td><%= u.email %></td>
          <td><span class="role-badge role-<%= u.role %>"><%= u.role.replace('_', ' ') %></span></td>
          <td>
            <% if (u.role === 'shop_owner' && u.login_expiry) { %>
              <span class="countdown-chip" data-expiry="<%= new Date(u.login_expiry).toISOString() %>">
                <i class="lucide-clock" style="font-size:10px;"></i>
                <span class="countdown-text"></span>
              </span>
            <% } else { %>
              —
            <% } %>
          </td>
          <td>
            <% if (u.is_active) { %>
              <span style="color:#2E7D52;font-weight:600;">Active</span>
            <% } else { %>
              <span style="color:#B00020;font-weight:600;">Inactive</span>
            <% } %>
          </td>
          <td class="action-btns">
            <button class="btn btn-sm btn-outline-gold" onclick='editUser(<%= JSON.stringify(u) %>)'>Edit</button>
            <button class="btn btn-sm btn-outline-red" onclick="deleteUser(<%= u.id %>)">Delete</button>
          </td>
        </tr>
      <% }) %>
      <% if (users.length === 0) { %>
        <tr><td colspan="7" style="text-align:center;color:#6B6B6B;padding:32px;">No users yet.</td></tr>
      <% } %>
    </tbody>
  </table>
</div>

<!-- User Drawer -->
<div class="drawer-overlay" id="userOverlay" onclick="closeUserDrawer()"></div>
<div class="drawer" id="userDrawer">
  <div class="drawer-header">
    <h3 id="userDrawerTitle">Add User</h3>
    <button class="icon-btn" onclick="closeUserDrawer()"><i class="lucide-x"></i></button>
  </div>
  <div class="drawer-body">
    <form id="userForm">
      <input type="hidden" id="userId">
      <div class="form-group">
        <label>Full Name</label>
        <input type="text" id="userName" class="form-control" required>
      </div>
      <div class="form-group">
        <label>Email</label>
        <input type="email" id="userEmail" class="form-control" required>
      </div>
      <div class="form-group">
        <label>Phone</label>
        <input type="text" id="userPhone" class="form-control">
      </div>
      <div class="form-group">
        <label>Role</label>
        <select id="userRole" class="form-control" onchange="toggleExpiryField()">
          <option value="broker">Broker</option>
          <option value="shop_owner">Shop Owner</option>
          <option value="admin">Admin</option>
        </select>
      </div>
      <div class="form-group" id="expiryGroup" style="display:none;">
        <label>Login Expiry (for Shop Owner)</label>
        <input type="datetime-local" id="userExpiry" class="form-control">
      </div>
      <div class="form-group">
        <label>Password <span id="pwdHint" style="color:#6B6B6B;font-weight:400;">(required for new users)</span></label>
        <input type="password" id="userPassword" class="form-control">
      </div>
      <div class="form-group">
        <label>Active</label>
        <select id="userActive" class="form-control">
          <option value="1">Active</option>
          <option value="0">Inactive</option>
        </select>
      </div>
    </form>
  </div>
  <div class="drawer-footer">
    <button class="btn btn-outline-maroon" onclick="closeUserDrawer()">Cancel</button>
    <button class="btn btn-gold" onclick="saveUser()">Save User</button>
  </div>
</div>

<%- include('layout/footer') %>
