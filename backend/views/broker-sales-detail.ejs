<% var pageTitle = 'Broker sales detail'; %>
<%- include('layout/header') %>

<div class="card">
  <div class="card-header" style="flex-wrap:wrap;gap:12px;align-items:center;">
    <div>
      <h3 style="margin:0;">Materials sold</h3>
      <p style="margin:6px 0 0;font-size:13px;color:var(--text-secondary);">
        <strong><%= broker.name %></strong>
        <span style="color:var(--text-muted);"> &lt;<%= broker.email %>&gt;</span>
      </p>
    </div>
    <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;">
      <span class="badge role-broker" style="font-size:11px;">Broker</span>
      <form method="get" action="/admin/reports/broker-sales/<%= broker.id %>" style="display:flex;align-items:center;gap:8px;">
        <select name="month" class="form-control" style="width:auto;min-width:120px;">
          <% for (var m = 1; m <= 12; m++) { %>
            <option value="<%= m %>" <%= month === m ? 'selected' : '' %>><%= ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'][m-1] %></option>
          <% } %>
        </select>
        <select name="year" class="form-control" style="width:auto;min-width:90px;">
          <% var cy = new Date().getFullYear(); for (var y = cy; y >= cy - 5; y--) { %>
            <option value="<%= y %>" <%= year === y ? 'selected' : '' %>><%= y %></option>
          <% } %>
        </select>
        <button type="submit" class="btn btn-maroon btn-sm">Apply</button>
      </form>
      <a href="/admin/reports/broker-sales?year=<%= year %>&month=<%= month %>" class="btn btn-outline-maroon btn-sm">← Back to all brokers</a>
    </div>
  </div>

  <p style="color:var(--text-secondary);font-size:13px;margin-bottom:16px;">
    Product-wise totals for <strong><%= monthLabel %> <%= year %></strong> (non-cancelled orders only).
  </p>

  <% if (lines.length === 0) { %>
    <p style="padding:24px;color:var(--text-secondary);text-align:center;">No sales recorded for this broker in the selected month.</p>
  <% } else { %>
  <table class="data-table">
    <thead>
      <tr>
        <th>#</th>
        <th>Product code</th>
        <th>Product / material</th>
        <th style="text-align:center;">Set size</th>
        <th style="text-align:right;">Bundles</th>
        <th style="text-align:right;">Sarees</th>
        <th style="text-align:right;">Amount (₹)</th>
      </tr>
    </thead>
    <tbody>
      <% lines.forEach(function(row, idx) { %>
        <tr>
          <td><%= idx + 1 %></td>
          <td><span class="badge" style="background:var(--bg-elevated);color:var(--primary);"><%= row.product_code %></span></td>
          <td><strong><%= row.product_name %></strong></td>
          <td style="text-align:center;"><%= row.set_size %></td>
          <td style="text-align:right;"><%= Number(row.bundles_sold || 0).toLocaleString('en-IN') %></td>
          <td style="text-align:right;"><%= Number(row.sarees_sold || 0).toLocaleString('en-IN') %></td>
          <td style="text-align:right;font-weight:600;">&#8377;<%= Number(row.amount || 0).toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></td>
        </tr>
      <% }) %>
    </tbody>
    <tfoot>
      <tr style="background:var(--bg-elevated);font-weight:700;">
        <td colspan="4" style="text-align:right;">Subtotal (this page)</td>
        <td style="text-align:right;"><%= Number(lineBundles).toLocaleString('en-IN') %></td>
        <td style="text-align:right;"><%= Number(lineSarees).toLocaleString('en-IN') %></td>
        <td style="text-align:right;">&#8377;<%= Number(lineTotal).toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></td>
      </tr>
    </tfoot>
  </table>
  <% } %>
</div>

<%- include('layout/footer') %>
