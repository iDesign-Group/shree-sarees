<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Shree Sarees - Admin Login</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/shree-sarees-theme.css">
</head>
<body class="login-page">
  <div class="login-card">
    <div class="logo-monogram">SS</div>
    <h1>Shree Sarees</h1>
    <p class="subtitle">Admin Panel Login</p>

    <% if (error) { %>
      <div class="login-error"><%= error %></div>
    <% } %>

    <form method="POST" action="/admin/login">
      <div class="form-group">
        <label>Email Address</label>
        <input type="email" name="email" class="form-control" placeholder="admin@shreesarees.com" required>
      </div>
      <div class="form-group">
        <label>Password</label>
        <input type="password" name="password" class="form-control" placeholder="Enter your password" required>
      </div>
      <button type="submit" class="btn btn-gold" style="margin-top: 8px;">Sign In</button>
    </form>
  </div>
</body>
</html>
